DATABASE_URL=postgresql+asyncpg://agency:agency@localhost:5432/agency_brain
# Restricted role for the API request path (subject to row-level security).
# Workers/Alembic use DATABASE_URL (owner, bypasses RLS). Leave blank to disable
# enforcement (API connects as owner). In prod, provision app_user with a strong
# password from your secrets manager.
APP_DATABASE_URL=postgresql+asyncpg://app_user:app_user@localhost:5432/agency_brain
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=            # Gemini API key (embeddings + chat) — aistudio.google.com/apikey
JWT_SECRET=change_me
# Separate secret for signing OAuth state tokens (falls back to JWT_SECRET if blank).
# Generate: uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
OAUTH_STATE_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/integrations/slack/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/integrations/jira/callback
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536
CHAT_MODEL=gemini-2.5-flash
# comma-separated allowed frontend origins (add future apps here)
CORS_ORIGINS=http://localhost:3000
# Fernet key(s) for encrypting OAuth tokens at rest, NEWEST FIRST (comma-separated).
# Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In prod, inject from your secrets manager — never commit a real key.
TOKEN_ENCRYPTION_KEYS=
